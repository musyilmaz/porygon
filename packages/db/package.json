{
  "name": "@porygon/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "echo 'build: placeholder'",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integration": "vitest run --project db-integration",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/seed.ts",
    "db:unseed": "tsx src/unseed.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10",
    "@porygon/shared": "workspace:*",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@porygon/eslint-config": "workspace:*",
    "@porygon/typescript-config": "workspace:*",
    "@porygon/vitest-config": "workspace:*",
    "@vitest/coverage-v8": "^3",
    "dotenv": "^16",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^3"
  }
}
