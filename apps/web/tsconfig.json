{
  "extends": "@porygon/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@porygon/ui/*": ["../../packages/ui/src/*"],
      "@porygon/auth": ["../../packages/auth/src/index.ts"],
      "@porygon/auth/*": ["../../packages/auth/src/*"],
      "@porygon/shared": ["../../packages/shared/src/index.ts"],
      "@porygon/shared/validators": ["../../packages/shared/src/validators/index.ts"],
      "@porygon/services": ["../../packages/services/src/index.ts"]
    }
  },
  "include": ["src", "next-env.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "dist", ".next", ".turbo"]
}
